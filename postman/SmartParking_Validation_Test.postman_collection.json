{
	"info": {
		"name": "Smart Parking - Validate Xe Vao/Xe Ra",
		"description": "Test validation cho 3 trang: Tong quan bai, Xe vao, Xe ra.\n\nTruoc khi test, hay login de lay JWT token va paste vao Authorization tab.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{jwt_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080"
		},
		{
			"key": "jwt_token",
			"value": "PASTE_JWT_TOKEN_HERE",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. Tong Quan Bai (Parking Area Summary)",
			"item": [
				{
					"name": "GET Options - Lay danh sach bai",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/api/v1/parking-area-summary/options",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "parking-area-summary", "options"]
						}
					}
				},
				{
					"name": "GET Areas - Mac dinh (khong filter)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/api/v1/parking-area-summary",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "parking-area-summary"]
						}
					}
				},
				{
					"name": "GET Areas - Filter theo building + floor",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/api/v1/parking-area-summary?buildingCode=LK&floorNumber=1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "parking-area-summary"],
							"query": [
								{ "key": "buildingCode", "value": "LK" },
								{ "key": "floorNumber", "value": "1" }
							]
						}
					}
				}
			]
		},
		{
			"name": "2. Xe Vao (Parking Entry)",
			"item": [
				{
					"name": "CHECK - Hop le (co bien so)",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{base_url}}/api/v1/parking-entry/check",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "parking-entry", "check"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"licensePlate\": \"51A-123.45\",\n  \"vehicleType\": \"CAR\"\n}"
						}
					}
				},
				{
					"name": "CHECK - FAIL blank licensePlate (400)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 400', function () { pm.response.to.have.status(400); });",
									"pm.test('Has validation error', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.errors).to.exist;",
									"    pm.expect(json.errors.licensePlate).to.equal('Bien so xe khong duoc de trong');",
									"    pm.expect(json.message).to.equal('Validation failed');",
									"});"

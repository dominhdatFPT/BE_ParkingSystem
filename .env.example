# ============================================================
# Smart Parking – BE Environment Variables
# Copy file này thành .env rồi điền giá trị thật
# ============================================================

# ── VNPay (lấy từ sandbox.vnpayment.vn) ─────────────────────
# Đăng nhập sandbox → Thông tin tài khoản → Thông tin merchant
VNP_TMN_CODE=YOUR_SANDBOX_TMN_CODE
VNP_HASH_SECRET=YOUR_SANDBOX_HASH_SECRET

# URL cổng thanh toán (giữ nguyên sandbox khi test)
VNP_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Return URL: VNPay redirect browser user về đây sau khi thanh toán
# Phải đăng ký chính xác URL này trong cổng VNPay sandbox
VNP_RETURN_URL=http://localhost:8080/api/payments/vnpay/return

# IPN URL: VNPay gọi server-to-server (phải public, không qua firewall)
# Đăng ký tại: sandbox → Merchant → Cấu hình → IPN URL
# VNP_IPN_URL=http://your-public-ip:8080/api/payments/vnpay/ipn

# URL trang kết quả trên FE (BE redirect về đây sau khi xử lý return)
VNP_FE_RESULT_URL=http://localhost:5173/subscription/result

# Thời gian hết hạn đơn hàng (phút, mặc định 15)
VNP_ORDER_EXPIRE_MINUTES=15

# ── Database ──────────────────────────────────────────────────
# (đã có trong application.yml, có thể override qua .env)
# SPRING_DATASOURCE_URL=jdbc:postgresql://...
# SPRING_DATASOURCE_USERNAME=...
# SPRING_DATASOURCE_PASSWORD=...

# ── JWT ───────────────────────────────────────────────────────
# APP_JWT_SECRET=...

# ── Gmail SMTP (gửi OTP quên mật khẩu) ──────────────────────
# Bước 1: Bật 2FA tại myaccount.google.com/security
# Bước 2: Tạo App Password tại myaccount.google.com/apppasswords
# Bước 3: Điền email và App Password (16 ký tự, không có khoảng trắng) vào đây
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# ── Crypto (AES encrypt partnerToken) ────────────────────────
CRYPTO_AES_SECRET_KEY=SmartParkingAESKey2024VerySecure!
